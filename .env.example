NODE_ENV=development
PORT=5000

# Alpaca paper trading credentials (https://alpaca.markets)
ALPACA_API_KEY=your_paper_api_key
ALPACA_API_SECRET=your_paper_api_secret
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# MongoDB (optional for v1 — JSON file storage is used by default)
# MONGO_URI=mongodb://localhost:27017/trading-bot

# Strategy settings
DEFAULT_TIMEFRAME=15Min
RISK_PERCENT=0.005
MAX_DAILY_LOSS_PERCENT=0.02
MAX_OPEN_POSITIONS=3

# Set to true to also scan BTC/USD, ETH/USD, SOL/USD
ENABLE_CRYPTO=false

# Must stay "paper" in v1
RUN_MODE=paper
