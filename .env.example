NODE_ENV=development
PORT=5000

# Alpaca paper trading credentials (https://alpaca.markets)
ALPACA_API_KEY=your_paper_api_key
ALPACA_API_SECRET=your_paper_api_secret
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# MongoDB (required — use MongoDB Atlas for production)
MONGO_URI=mongodb://localhost:27017/trading-bot
MONGO_DB_NAME=trading-bot

# Strategy settings
DEFAULT_TIMEFRAME=15Min
RISK_PERCENT=0.005

MAX_DAILY_LOSS_PERCENT=0.02
MAX_OPEN_POSITIONS=5

# Asset classes — set to false to disable; both default to true if omitted
ENABLE_STOCKS=true
ENABLE_CRYPTO=true

# Must stay "paper" in v1
RUN_MODE=paper

# Forced first trade — paper debug only. Remove after validating the pipeline.
# FORCE_FIRST_TRADE=true
# FORCE_FIRST_TRADE_SYMBOL=BTC/USD
# FORCE_FIRST_TRADE_QTY=0.001

# Dev/testing bypass — set to true to force NEW_YORK session (stocks + crypto eligible).
# Never use in production.
# SKIP_MARKET_HOURS=true

# Scheduler auth secret for POST /api/cycle/run
CRON_SECRET=replace_with_long_random_secret

# Allow manual cycle trigger from dashboard (POST /api/cycle/manual-run)
ALLOW_MANUAL_TRIGGER=true

# Runtime stale recovery timeout (minutes)
CYCLE_RUNTIME_STALE_MINUTES=40

# Candidate ranking — max approved signals that proceed to risk guards per cycle
MAX_CANDIDATES_PER_CYCLE=3

# Portfolio risk
MAX_TOTAL_RISK_PCT=5
MAX_CORRELATED_POSITIONS=3
DRAWDOWN_THROTTLE_PCT=1

# Exit engine
MAX_HOLD_BARS=48
TRAILING_ATR_MULTIPLIER=1.5
