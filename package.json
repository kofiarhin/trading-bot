{
  "name": "trading-bot",
  "version": "1.0.0",
  "description": "Alpaca autopilot trading engine — momentum breakout strategy",
  "type": "module",
  "scripts": {
    "server": "node -r ./src/config/loadEnv.cjs src/server/index.js",
    "autopilot": "node -r ./src/config/loadEnv.cjs src/autopilot.js",
    "autopilot:dry": "node -r ./src/config/loadEnv.cjs src/autopilot.js --dry-run",
    "worker:15m": "node -r ./src/config/loadEnv.cjs src/worker15m.js",
    "strategy:simulate": "node -r ./src/config/loadEnv.cjs src/simulateStrategy.js",
    "trade": "node src/index.js",
    "trade:dry": "node src/index.js --dry-run",
    "db:migrate": "node -r ./src/config/loadEnv.cjs src/db/migrate.js",
    "migrate:mongo": "node -r ./src/config/loadEnv.cjs src/db/migrate.js",
    "monitor": "node src/monitor.js",
    "monitor:dry": "node src/monitor.js --dry-run",
    "test": "cross-env NODE_OPTIONS=--experimental-vm-modules jest --runInBand",
    "test:watch": "cross-env NODE_OPTIONS=--experimental-vm-modules jest --watch",
    "client": "npm run dev --prefix client",
    "dev": "concurrently \"npm run server\" \"npm run client\""
  },
  "jest": {
    "testEnvironment": "node",
    "transform": {},
    "testMatch": [
      "**/tests/**/*.test.js"
    ],
    "testPathIgnorePatterns": [
      "/node_modules/",
      "/tests/parser.test.js",
      "/tests/tradePlanner.test.js",
      "/tests/tradePlanner.crypto.test.js",
      "/tests/alpaca.crypto.test.js",
      "/tests/journal/tradeJournal.test.js"
    ]
  },
  "license": "MIT",
  "devDependencies": {
    "concurrently": "^9.2.1",
    "crawlee": "^3.16.0",
    "cross-env": "^10.1.0",
    "jest": "^30.3.0",
    "mongodb-memory-server": "^11.0.1",
    "playwright": "^1.59.1",
    "supertest": "^7.2.2"
  },
  "dependencies": {
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "mongoose": "^9.4.1"
  }
}
